# Email (verification & password reset)
# Option 1: SendGrid HTTP API (recommended - single sender verification only, no domain needed)
# 1. Sign up at https://sendgrid.com (free: 100 emails/day)
# 2. Create a sender: Settings > Sender Authentication > Create New Sender (verify your email)
# 3. Create API key: Settings > API Keys > Create API Key (Full Access)
SENDGRID_API_KEY=
SENDGRID_FROM=oh_djaidja@esi.dz
# Option 2: Resend HTTP API (needs domain verification for sending to anyone)
RESEND_API_KEY=
RESEND_FROM=onboarding@resend.dev
