RESEND_API_KEY=
# Resend sender (default: onboarding@resend.dev - no verification needed)
# For custom domain, verify it in Resend dashboard first
RESEND_FROM=onboarding@resend.dev
# Option 2: SMTP (fallback)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@dr-djaidja.dz
